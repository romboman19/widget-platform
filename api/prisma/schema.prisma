generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Experiment {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name        String
  status      ExperimentStatus @default(DRAFT)
  trafficAllocation Int   @default(50)  // % for variant A
  variants    Json     // [{ widgetId, weight }]
  startDate   DateTime?
  endDate     DateTime?
  winnerId    String?  // winning variant
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  analytics   AnalyticsEvent[]
}

enum ExperimentStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sites     Site[]
  templates Template[]
  mediaFolders MediaFolder[]
  mediaFiles   MediaFile[]
}

model Site {
  id             String   @id @default(cuid())
  slug           String   @unique  // used in ?site=slug
  name           String
  domain         String   // for CORS validation
  screenshotUrl  String?  // path to screenshot image
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  widgets        Widget[]
  experiments    Experiment[]
  analytics      AnalyticsEvent[]
}

model Widget {
  id        String     @id @default(cuid())
  siteId    String
  site      Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  type      WidgetType
  name      String
  enabled   Boolean    @default(true)
  config    Json       // all widget-specific settings
  rules     Json?      // URL rules, device rules
  position  Json?      // placement settings
  triggers  Json?      // popup triggers
  priority  Int        @default(0)
  experimentId String? // Assigned to A/B experiment
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  analytics AnalyticsEvent[]
}

enum WidgetType {
  FLOATING_MENU
  POPUP_CALLBACK
  POPUP_BANNER
  STICKY_BAR
  SIDE_TAB
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  widgetId    String?
  widget      Widget?  @relation(fields: [widgetId], references: [id], onDelete: SetNull)
  experimentId String?
  experiment  Experiment? @relation(fields: [experimentId], references: [id], onDelete: SetNull)
  variantId   String?  // which variant was shown
  event       String   // 'view', 'click', 'submit', 'open', 'close'
  channel     String?  // 'telegram', 'viber', 'phone', etc.
  page        String?  // page URL
  device      String?  // 'desktop' or 'mobile'
  ip          String?
  userAgent   String?
  meta        Json?    // extra data
  createdAt   DateTime @default(now())

  @@index([siteId, createdAt])
  @@index([widgetId, event])
  @@index([experimentId, variantId])
}

model Template {
  id          String     @id @default(cuid())
  userId      String?
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  name        String     // Template name
  description String?    // Description of what this template does
  type        WidgetType
  config      Json       // Widget configuration
  position    Json?      // Default position
  triggers    Json?      // Default triggers
  rules       Json?      // Default rules
  isGlobal    Boolean    @default(false)  // Available to all users
  usageCount  Int        @default(0)      // How many times used
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([isGlobal, usageCount])
  @@index([userId])
}

// === Media Library ===

model MediaFolder {
  id          String    @id @default(cuid())
  userId      String?
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  name        String
  parentId    String?
  parent      MediaFolder? @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    MediaFolder[] @relation("FolderTree")
  files       MediaFile[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
}

enum MediaType {
  SVG
  PNG
  JPG
  WEBP
  GIF
  VIDEO
  FONT
}

model MediaFile {
  id          String    @id @default(cuid())
  userId      String?
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  folderId    String?
  folder      MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  name        String
  slug        String    @unique

  type        MediaType
  mimeType    String
  subtype     String    // 'icon', 'avatar', 'banner', etc.

  originalUrl String
  url         String
  thumbnailUrl String?

  channelType String?
  isDefault   Boolean   @default(false)
  svgContent  String?

  size        Int
  hash        String    @unique
  width       Int?
  height      Int?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, folderId])
  @@index([type, subtype])
  @@index([channelType])
}
