# ──────────────────────────────────────────────
# Widget Platform — Configuration
# ──────────────────────────────────────────────

# ─── SECURITY: обов'язково змінити перед деплоєм! ───

# Пароль PostgreSQL (мінімум 16 символів)
# Згенерувати: openssl rand -base64 24
DB_PASSWORD=changeme

# JWT секрет (мінімум 32 символи)
# Згенерувати: openssl rand -hex 32
JWT_SECRET=change-this-secret-to-random-string

# Адмін (створюється при першому запуску)
ADMIN_EMAIL=admin@yourdomain.ua
ADMIN_PASSWORD=changeme-min-8-chars

# ─── Мережа ───

# Порт для HTTP (за Nginx Proxy Manager)
HTTP_PORT=8090

# Публічний URL (для скрипту віджету)
PUBLIC_URL=https://widgets.yourdomain.ua

# ─── NGINX: дозволені домени для CORS ───
# Редагувати безпосередньо в nginx/nginx.conf:
#   map $http_origin $cors_ok { ... }
# Додати свої домени там
